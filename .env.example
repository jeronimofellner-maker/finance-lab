# Copiá este archivo a .env y completá. .env NUNCA se versiona (está en .gitignore).
# Para GitHub Actions, estos mismos valores se cargan como "Secrets" del repo (ver README).

# --- Gmail SMTP (envío de mails) ---
# GMAIL_USER: tu casilla emisora/receptora
GMAIL_USER=tu-mail@gmail.com
# GMAIL_APP_PASSWORD: app password de 16 caracteres SIN espacios (ver README, sección Gmail)
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# A dónde llega todo (brief diario + alertas). Normalmente el mismo Gmail.
MAIL_TO=tu-mail@gmail.com

# --- Opcionales ---
# User-Agent que pide la SEC para identificarte en sus APIs (poné tu mail real).
SEC_USER_AGENT=Tu Nombre tu-mail@example.com
